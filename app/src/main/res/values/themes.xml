<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Base application theme. -->
    <style name="Base.Theme.PalamiGoPOS" parent="Theme.Material3.DayNight.NoActionBar">
        <!-- Customize your light theme here. -->
        <item name="colorPrimary">@color/pg_gold</item>
        <item name="colorOnPrimary">@color/black</item>
        <item name="colorSecondary">@color/pg_gold</item>
        <item name="colorOnSecondary">@color/black</item>
        <item name="colorTertiary">@color/pg_gold_dark</item>
        <item name="colorOnTertiary">@color/black</item>

        <item name="android:statusBarColor">@color/pg_background</item>
        <item name="android:navigationBarColor">@color/pg_background</item>
        
        <!-- Prevent white flash on startup (Android 8.1 and below) -->
        <item name="android:windowBackground">@color/pg_background</item>
    </style>

    <style name="Theme.PalamiGoPOS" parent="Base.Theme.PalamiGoPOS" />

    <!-- PIN Button Style -->
    <style name="PinButton" parent="Widget.Material3.Button.OutlinedButton">
        <item name="android:layout_width">80dp</item>
        <item name="android:layout_height">80dp</item>
        <item name="android:textSize">28sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:textColor">@color/white</item>
        <item name="backgroundTint">#2D2D30</item>
        <item name="strokeColor">@color/pg_gold</item>
        <item name="strokeWidth">1dp</item>
        <item name="cornerRadius">40dp</item>
    </style>

    <!-- PIN Button Small (for dialog) -->
    <style name="PinButtonSmall" parent="Widget.Material3.Button.OutlinedButton">
        <item name="android:layout_width">64dp</item>
        <item name="android:layout_height">64dp</item>
        <item name="android:textSize">24sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:textColor">@color/white</item>
        <item name="backgroundTint">#2D2D30</item>
        <item name="strokeColor">@color/pg_gold</item>
        <item name="strokeWidth">1dp</item>
        <item name="cornerRadius">32dp</item>
    </style>
</resources>