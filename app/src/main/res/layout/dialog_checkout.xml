<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@color/pg_surface"
    android:orientation="vertical"
    android:padding="18dp">

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Checkout"
        android:textColor="@color/pg_text_primary"
        android:textSize="18sp"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/tvTotal"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="10dp"
        android:textColor="@color/pg_gold"
        android:textSize="24sp"
        android:textStyle="bold" />

    <com.google.android.material.textfield.TextInputLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="14dp"
        app:boxBackgroundMode="filled"
        app:boxBackgroundColor="@color/pg_surface_variant"
        app:hintTextColor="@color/pg_text_secondary">

        <com.google.android.material.textfield.TextInputEditText
            android:id="@+id/etCash"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Cash received"
            android:inputType="numberDecimal"
            android:textColor="@color/pg_text_primary"
            android:textColorHint="@color/pg_text_secondary" />

    </com.google.android.material.textfield.TextInputLayout>

    <TextView
        android:id="@+id/tvPaymentStatus"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="10dp"
        android:textColor="@color/pg_text_secondary"
        android:textSize="14sp" />

</LinearLayout>
