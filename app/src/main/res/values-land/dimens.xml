<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- Landscape phone adaptations - more horizontal space, less vertical space -->
    
    <!-- Product grid - more columns possible in landscape -->
    <integer name="product_span_count">3</integer>
    
    <!-- Compact cart for landscape (less vertical space available) -->
    <dimen name="cart_container_margin">8dp</dimen>
    <dimen name="cart_container_padding">10dp</dimen>
    <dimen name="cart_container_corner">14dp</dimen>
    
    <!-- Cart items more compact in landscape -->
    <dimen name="cart_item_margin">3dp</dimen>
    <dimen name="cart_item_padding">10dp</dimen>
    <dimen name="cart_item_corner">10dp</dimen>
    <dimen name="cart_item_name_size">13sp</dimen>
    <dimen name="cart_item_price_size">11sp</dimen>
    <dimen name="cart_item_subtotal_size">12sp</dimen>
    
    <!-- Smaller qty buttons in landscape cart panel -->
    <dimen name="cart_qty_btn_size">40dp</dimen>
    <dimen name="cart_qty_text_width">36dp</dimen>
    <dimen name="cart_qty_text_size">13sp</dimen>
    
    <!-- Toolbar slightly smaller in landscape -->
    <dimen name="toolbar_height">52dp</dimen>
    <dimen name="toolbar_padding">4dp</dimen>
    <dimen name="toolbar_title_size">17sp</dimen>
    
    <!-- Compact chips for landscape -->
    <dimen name="chip_group_margin">6dp</dimen>
    <dimen name="chip_spacing">6dp</dimen>
    <dimen name="chip_text_size">13sp</dimen>
    <dimen name="chip_height">36dp</dimen>
    
    <!-- RecyclerView margins -->
    <dimen name="rv_margin_horizontal">8dp</dimen>
    <dimen name="rv_margin_top">6dp</dimen>
    
    <!-- Total and checkout -->
    <dimen name="cart_total_text_size">20sp</dimen>
    <dimen name="cart_label_text_size">12sp</dimen>
    <dimen name="checkout_btn_height">48dp</dimen>
    <dimen name="checkout_btn_corner">12dp</dimen>
    <dimen name="checkout_btn_text_size">14sp</dimen>
    <dimen name="checkout_btn_margin_top">6dp</dimen>
    
    <!-- Product cards slightly smaller in landscape -->
    <dimen name="product_card_margin">6dp</dimen>
    <dimen name="product_card_padding">11dp</dimen>
    <dimen name="product_card_corner">12dp</dimen>
    <dimen name="product_name_text_size">14sp</dimen>
    <dimen name="product_price_text_size">12sp</dimen>
</resources>
